{
  "name": "opencode-otel",
  "version": "0.3.1",
  "description": "OpenCode plugin for unified observability via OpenTelemetry — export session traces and logs to Langfuse, LangSmith, Jaeger, Grafana Tempo, or any OTLP backend",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "otel.json.example"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external @opencode-ai",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "opentelemetry",
    "otel",
    "observability",
    "langfuse",
    "langsmith",
    "jaeger",
    "tracing",
    "plugin"
  ],
  "author": "NeverMore93",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeverMore93/opencode-otel.git"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.1.0"
  },
  "dependencies": {
    "@langfuse/otel": "^5.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-logs": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1"
  }
}
